# Hosted Supabase: reviewmycocktail (project ref hujijopocbmmflmtthtk, region us-east-1)
# Copy to `.env` (gitignored). Get the DB password from:
# Dashboard → Project Settings → Database → Database password
# Use the "Connection pooling" URI (transaction mode), or build:
DATABASE_URL=postgresql://postgres.hujijopocbmmflmtthtk:[PASSWORD]@aws-0-us-east-1.pooler.supabase.com:6543/postgres
#
# Production: set DATABASE_URL to the same pooler URI in your host's secret/env store
# (Railway, Fly.io, etc.). Never commit real passwords or service_role keys.
#
# Troubleshooting: if `supabase db query --linked` fails with cli_login SASL auth, re-run
# `supabase link` (you will be prompted for the database password) or run SQL in the dashboard.

# Local Supabase (requires Docker: `bun run supabase:start`, then `bun run supabase:db:reset`)
# DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:54322/postgres
